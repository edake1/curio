// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Moral Dilemma - Complex ethical questions
model Dilemma {
  id          String   @id @default(cuid())
  question    String   // The full question/scenario
  optionA     String   // First choice
  optionB     String   // Second choice
  argumentA   String?  // Best case for option A (shown post-vote)
  argumentB   String?  // Best case for option B (shown post-vote)
  category    String   // "ethics", "family", "relationships", "career", etc.
  difficulty  String   @default("medium") // easy, medium, hard
  isDaily     Boolean  @default(false) // Is this today's featured dilemma?
  dailyDate   DateTime? // When it was featured as daily
  votesA      Int      @default(0)
  votesB      Int      @default(0)
  totalVotes  Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  votes       Vote[]
}

// Individual votes
model Vote {
  id         String   @id @default(cuid())
  dilemmaId  String
  choice     String   // "A" or "B"
  sessionId  String   // Anonymous session identifier
  createdAt  DateTime @default(now())

  dilemma    Dilemma  @relation(fields: [dilemmaId], references: [id], onDelete: Cascade)

  @@index([dilemmaId])
  @@index([sessionId])
}

// Delete choices for "Pick One to Delete" app
model DeleteChoice {
  id          String   @id @default(cuid())
  optionA     String   // First thing to potentially delete
  optionB     String   // Second thing
  description String?  // Context/description
  category    String   // "technology", "concepts", "habits", "existence"
  votesA      Int      @default(0)
  votesB      Int      @default(0)
  totalVotes  Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  deleteVotes DeleteVote[]
}

// Votes for delete choices
model DeleteVote {
  id              String   @id @default(cuid())
  deleteChoiceId  String
  choice          String   // "A" or "B"
  sessionId       String
  createdAt       DateTime @default(now())

  deleteChoice    DeleteChoice @relation(fields: [deleteChoiceId], references: [id], onDelete: Cascade)

  @@index([deleteChoiceId])
  @@index([sessionId])
}

// Global site statistics
model SiteStats {
  id                String   @id @default("default")
  totalDilemmaVotes Int      @default(0)
  totalDeleteVotes  Int      @default(0)
  totalVisitors     Int      @default(0)
  lastUpdated       DateTime @updatedAt
}

// Visitor sessions for tracking
model VisitorSession {
  id           String   @id @default(cuid())
  sessionId    String   @unique
  firstVisit   DateTime @default(now())
  lastVisit    DateTime @updatedAt
  visitCount   Int      @default(1)
}

// Grand Dao — debate vote tallies (keyed by debate slug)
model DaoDebate {
  id        String   @id
  votesA    Int      @default(0)
  votesB    Int      @default(0)
  updatedAt DateTime @updatedAt
}

// Your Last Words — anonymous public submissions + upvotes
model LastWords {
  id          String   @id @default(cuid())
  text        String
  addressedTo String?  // "world" | "someone-i-love" | "myself" | "my-children" | "a-stranger"
  sessionId   String?  // one submission per session
  upvotes     Int      @default(0)
  createdAt   DateTime @default(now())

  @@index([sessionId])
  @@index([addressedTo])
  @@index([createdAt])
  @@index([upvotes])
}

// Hikmah — Global Wisdom sayings
model WisdomSaying {
  id              String   @id @default(cuid())
  text            String   // The saying in English
  originalText    String?  // Original language text (native script)
  attribution     String   // "Japanese Proverb", "Rumi", "Yoruba Proverb", etc.
  origin          String   // Specific country or culture
  region          String   // africa, east-asia, south-asia, southeast-asia, middle-east, europe, americas, indigenous, oceania
  category        String   // resilience, patience, love, death, wisdom, justice, community, humility, nature, truth, action, knowledge, gratitude, unity, courage, time, change, character
  contextOrigin   String?  // Where it comes from — AI-generated on first view
  contextMeaning  String?  // What it means beneath the surface
  contextPractice String?  // How to apply it to life
  relatedIds      String?  // JSON array of related saying IDs
  dailyDate       DateTime? @unique // When featured as daily saying
  totalReflections Int     @default(0)
  aiGenerated     Boolean  @default(false)
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  reflections     WisdomReflection[]

  @@index([region])
  @@index([category])
  @@index([dailyDate])
  @@index([active])
}

// Hikmah — Community reflections on sayings
model WisdomReflection {
  id        String   @id @default(cuid())
  sayingId  String
  text      String
  tag       String?  // "resonates" | "disagree" | "reminds-me" | "in-my-culture"
  sessionId String?
  upvotes   Int      @default(0)
  createdAt DateTime @default(now())

  saying    WisdomSaying @relation(fields: [sayingId], references: [id], onDelete: Cascade)

  @@index([sayingId])
  @@index([sessionId])
  @@index([createdAt])
  @@index([upvotes])
}
